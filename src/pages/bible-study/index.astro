---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('bible-study', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Bible Study — Michael Kong" description="Bible study notes and reflections by Michael Kong.">
  <h1>Bible Study</h1>
  {notes.length === 0 ? (
    <p>No notes yet. Check back soon!</p>
  ) : (
    <ul class="post-list">
      {notes.map((note) => (
        <li>
          <PostCard
            title={note.data.title}
            href={`/bible-study/${note.id.replace(/\.md$/, '')}/`}
            pubDate={note.data.pubDate}
            description={note.data.description}
            tags={note.data.tags}
          />
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
