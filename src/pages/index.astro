---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const bibleStudyNotes = (await getCollection('bible-study', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Michael Kong" description="Personal blog and Bible study notes by Michael Kong.">
  <section>
    <h1>Hey, I'm Michael</h1>
    <p>Welcome to my corner of the internet. I write about faith, technology, and life. Browse my <a href="/blog/">blog</a> or check out my <a href="/bible-study/">Bible study notes</a>.</p>
  </section>

  {blogPosts.length > 0 && (
    <section style="margin-top:2rem;">
      <h2>Recent Posts</h2>
      <ul class="post-list">
        {blogPosts.map((post) => (
          <li>
            <PostCard
              title={post.data.title}
              href={`/blog/${post.id.replace(/\.md$/, '')}/`}
              pubDate={post.data.pubDate}
              description={post.data.description}
              tags={post.data.tags}
            />
          </li>
        ))}
      </ul>
      <p style="margin-top:1rem;"><a href="/blog/">View all posts &rarr;</a></p>
    </section>
  )}

  {bibleStudyNotes.length > 0 && (
    <section style="margin-top:2rem;">
      <h2>Recent Bible Study Notes</h2>
      <ul class="post-list">
        {bibleStudyNotes.map((note) => (
          <li>
            <PostCard
              title={note.data.title}
              href={`/bible-study/${note.id.replace(/\.md$/, '')}/`}
              pubDate={note.data.pubDate}
              description={note.data.description}
              tags={note.data.tags}
            />
          </li>
        ))}
      </ul>
      <p style="margin-top:1rem;"><a href="/bible-study/">View all notes &rarr;</a></p>
    </section>
  )}
</BaseLayout>
