---
import BaseLayout from './BaseLayout.astro';
import CopyButton from '../components/CopyButton.astro';
import FontSizer from '../components/FontSizer.astro';

interface Props {
  frontmatter: {
    title: string;
    number: number;
    tags?: string[];
    firstLine?: string;
  };
}

const { frontmatter } = Astro.props;
---

<BaseLayout
  title={`${frontmatter.title} — Sunday School Songs`}
  description={frontmatter.firstLine || frontmatter.title}
>
  <article class="song">
    <header class="article-header song-header">
      <p class="song-back"><a href="/songs/">← All songs</a></p>
      <h1>{frontmatter.title}</h1>
      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="tags">
          {frontmatter.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
      <div class="song-tools">
        <CopyButton target="#song-lyrics" label="Copy lyrics" />
        <FontSizer target="#song-lyrics" />
      </div>
    </header>

    <div id="song-lyrics" class="lyrics">
      <slot />
    </div>
  </article>
</BaseLayout>
