---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="song-search">
  <label class="song-search-label" for="song-search-input">
    Search songs
  </label>
  <input
    type="search"
    id="song-search-input"
    class="song-search-input"
    placeholder="Search by title, first line, or tag…"
    autocomplete="off"
  />
  {tags.length > 0 && (
    <div class="tag-chips" role="group" aria-label="Filter by tag">
      <button type="button" class="tag-chip is-active" data-tag-filter="">All</button>
      {tags.map((tag) => (
        <button type="button" class="tag-chip" data-tag-filter={tag}>{tag}</button>
      ))}
    </div>
  )}
  <p class="song-search-count" aria-live="polite"></p>
</div>

<script>
  const input = document.querySelector<HTMLInputElement>('#song-search-input');
  const chips = document.querySelectorAll<HTMLButtonElement>('.tag-chip');
  const count = document.querySelector<HTMLElement>('.song-search-count');
  const items = document.querySelectorAll<HTMLElement>('[data-song-item]');
  const sections = document.querySelectorAll<HTMLElement>('[data-song-section]');

  let activeTag = '';

  function applyFilter() {
    const q = (input?.value || '').trim().toLowerCase();
    let visible = 0;
    items.forEach((item) => {
      const title = (item.dataset.title || '').toLowerCase();
      const firstLine = (item.dataset.firstLine || '').toLowerCase();
      const itemTags = (item.dataset.tags || '').toLowerCase();
      const matchText = !q || title.includes(q) || firstLine.includes(q) || itemTags.includes(q);
      const matchTag = !activeTag || itemTags.split('|').includes(activeTag.toLowerCase());
      const show = matchText && matchTag;
      item.hidden = !show;
      if (show) visible++;
    });
    sections.forEach((section) => {
      const hasVisible = section.querySelectorAll<HTMLElement>('[data-song-item]:not([hidden])').length > 0;
      section.hidden = !hasVisible;
    });
    if (count) count.textContent = `${visible} song${visible === 1 ? '' : 's'}`;
  }

  input?.addEventListener('input', applyFilter);
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.remove('is-active'));
      chip.classList.add('is-active');
      activeTag = chip.dataset.tagFilter || '';
      applyFilter();
    });
  });

  applyFilter();
</script>
